  "formTitle": "KUNPENSCOUTER",
  "version": "1.0",
  "basics": {
    "description": "Pre-match fields displayed at the top of the form",
    "fields": [
      {
        "type": "checkbox",
        "name": "noshow",
        "label": "No Show",
        "hidesForm": true,
        "dbColumn": {
          "type": "BOOLEAN",
          "default": false
        }
      }
    ]
  },
  "sections": [
    {
      "id": "auto",
      "header": "Auto",
      "showWhen": {
        "field": "noshow",
        "equals": false
      },
      "fields": [
        {
          "type": "imageSelect",
          "name": "autostartpos",
          "label": "Starting Position",
          "subHeader": "Starting Position",
          "required": true,
          "imageTag": "field_map",
          "optionLayout": {
            "top": "33%",
            "distribution": "even"
          },
          "options": [
            {
              "value": 0,
              "label": "Trench (L)"
            },
            {
              "value": 1,
              "label": "Left Bump"
            },
            {
              "value": 2,
              "label": "Hub"
            },
            {
              "value": 3,
              "label": "Right Bump"
            },
            {
              "value": 4,
              "label": "Trench (R)"
            }
          ],
          "dbColumn": {
            "type": "INTEGER",
            "default": null
          }
        },
        {
          "type": "multiSelect",
          "subHeader": "Intake",
          "name": "autoIntakeOptions",
          "options": [
            {
              "name": "fueldepotintake",
              "label": "Fuel Depot",
              "dbColumn": {
                "type": "BOOLEAN",
                "default": false
              }
            },
            {
              "name": "fueloutpostintake",
              "label": "Fuel Outpost (HP)",
              "dbColumn": {
                "type": "BOOLEAN",
                "default": false
              }
            }
          ]
        },
        {
          "type": "collapsible",
          "id": "autoShootOnTheMoveSection",
          "trigger": {
            "type": "checkbox",
            "name": "autoshootonthemove",
            "label": "Shooting on the Move?",
            "dbColumn": {
              "type": "BOOLEAN",
              "default": false
            }
          },
          "content": [
            {
              "type": "starRating",
              "name": "autoshootonthemoverating",
              "label": "Shooting While Moving (Auto)",
              "description": "How well did the robot maintain speed and accuracy while shooting on the move during auto?",
              "max": 4,
              "ratingLabels": [
                "Robot slows significantly AND most shots miss while moving",
                "Robot maintains speed OR accuracy, but not both",
                "Robot maintains moderate speed and lands most shots",
                "Robot maintains full speed with consistent shot accuracy"
              ],
              "minWhenVisible": 1,
              "dbColumn": {
                "type": "INTEGER",
                "default": null
              }
            }
          ]
        },
        {
          "type": "starRating",
          "name": "autoshootingrate",
          "label": "Shooting Rate (Auto)",
          "description": "Estimated average fuel pieces scored per second during autonomous period",
          "max": 5,
          "ratingLabels": [
            "Under 1 fuel/sec",
            "1-4 fuel/sec",
            "5-10 fuel/sec",
            "11-20 fuel/sec",
            "20+ fuel/sec"
          ],
          "dbColumn": {
            "type": "INTEGER",
            "default": null
          }
        },
        {
          "type": "singleSelect",
          "subHeader": "End Position",
          "name": "autoclimb",
          "label": "Auto Climb",
          "dbColumn": {
            "type": "INTEGER",
            "default": 0
          },
          "options": [
            {
              "value": 0,
              "label": "None",
              "default": true
            },
            {
              "value": 1,
              "label": "Level 1 (15 pts)"
            },
            {
              "value": 2,
              "label": "Failed Climb"
            }
          ]
        }
      ]
    },
    {
      "id": "tele",
      "header": "Tele",
      "showWhen": {
        "field": "noshow",
        "equals": false
      },
      "fields": [
        {
          "type": "collapsible",
          "id": "teleShootOnTheMoveSection",
          "trigger": {
            "type": "checkbox",
            "name": "teleshootonthemove",
            "label": "Shooting on the Move?",
            "dbColumn": {
              "type": "BOOLEAN",
              "default": false
            }
          },
          "content": [
            {
              "type": "starRating",
              "name": "teleshootonthemoverating",
              "label": "Shooting While Moving (Tele)",
              "description": "How well did the robot maintain speed and accuracy while shooting on the move during teleop?",
              "max": 4,
              "ratingLabels": [
                "Robot slows significantly AND most shots miss while moving",
                "Robot maintains speed OR accuracy, but not both",
                "Robot maintains moderate speed and lands most shots",
                "Robot maintains full speed with consistent shot accuracy"
              ],
              "minWhenVisible": 1,
              "dbColumn": {
                "type": "INTEGER",
                "default": null
              }
            }
          ]
        },
        {
          "type": "starRating",
          "name": "teleshootingrate",
          "label": "Shooting Rate (Tele)",
          "description": "Estimated fuel pieces scored per second during teleop",
          "max": 5,
          "ratingLabels": [
            "Under 1 fuel/sec",
            "1-4 fuel/sec",
            "5-10 fuel/sec",
            "11-20 fuel/sec",
            "20+ fuel/sec"
          ],
          "dbColumn": {
            "type": "INTEGER",
            "default": null
          }
        },
        {
          "type": "starRating",
          "name": "driving",
          "label": "Driver Spatial Awareness",
          "description": "Driver's field navigation without blocking teammates or taking inefficient paths",
          "max": 4,
          "ratingLabels": [
            "Frequently blocks teammates and takes inefficient paths",
            "Occasionally blocks teammates or takes suboptimal routes",
            "Rarely blocks teammates and usually takes efficient paths",
            "Never blocks teammates and consistently takes optimal paths"
          ],
          "dbColumn": {
            "type": "INTEGER",
            "default": null
          }
        },
        {
          "type": "comment",
          "name": "drivingcomments",
          "label": "Driving Comments",
          "dbColumn": {
            "type": "TEXT",
            "default": null
          }
        },
        {
          "type": "collapsible",
          "id": "passingSection",
          "trigger": {
            "type": "checkbox",
            "name": "passing",
            "label": "Did the Robot Pass?",
            "dbColumn": {
              "type": "BOOLEAN",
              "default": false
            }
          },
          "content": [
            {
              "type": "starRating",
              "name": "passingrating",
              "label": "Passing",
              "description": "Ability to pass fuel to consistent target zone across distance",
              "max": 4,
              "ratingLabels": [
                "Rarely succeed passing attempts",
                "Passes from Neutral Zone or farther, but hit inconsistent target",
                "Passes consistently from Neutral Zone to target zone",
                "Makes consistent cross-court passes with accurate placement"
              ],
              "minWhenVisible": 1,
              "dbColumn": {
                "type": "INTEGER",
                "default": null
              }
            },
            {
              "type": "comment",
              "name": "passingcomments",
              "label": "Passing Comments",
              "dbColumn": {
                "type": "TEXT",
                "default": null
              }
            }
          ]
        },
        {
          "type": "collapsible",
          "id": "defenseSection",
          "trigger": {
            "type": "checkbox",
            "name": "defense",
            "label": "Playing Defense?",
            "dbColumn": {
              "type": "BOOLEAN",
              "default": false
            }
          },
          "content": [
            {
              "type": "starRating",
              "name": "defenseplayed",
              "label": "Defense Played",
              "description": "How effectively the robot disrupts opponent scoring OR movement when playing defense",
              "zeroLabel": "Did Not Defend",
              "max": 4,
              "ratingLabels": [
                "Defended robot continues normal scoring/movement",
                "Defended robot's scoring/movement is somewhat disrupted",
                "Defended robot's scoring/movement is significantly disrupted",
                "Defended robot is consistently unable to score/move freely"
              ],
              "minWhenVisible": 1,
              "dbColumn": {
                "type": "INTEGER",
                "default": null
              }
            },
            {
              "type": "comment",
              "name": "defensecomments",
              "label": "Defense Elaboration",
              "dbColumn": {
                "type": "TEXT",
                "default": null
              }
            }
          ]
        }
      ]
    },
