{
  "gameName": "rebuilt_2026",
  "displayName": "REBUILT 2026",
  "formTitle": "KUNPENGOUTER",
  "version": "1.0",
  "basics": {
    "description": "Pre-match fields displayed at the top of the form",
    "fields": [
      {
        "type": "checkbox",
        "name": "noshow",
        "label": "No Show",
        "hidesForm": true,
        "dbColumn": {
          "type": "BOOLEAN",
          "default": false
        }
      }
    ]
  },
  "sections": [
    {
      "id": "auto",
      "header": "Auto",
      "showWhen": {
        "field": "noshow",
        "equals": false
      },
      "fields": [
        {
          "type": "holdTimer",
          "name": "autofuelsuccess",
          "label": "Auto Fuel Time (s)",
          "buttonLabel": "Hold While Shooting Auto Fuel",
          "precision": 2,
          "dbColumn": {
            "type": "NUMERIC(10,3)",
            "default": 0
          },
          "scoutLeads": {
            "rateLabel": "Auto Balls / Second",
            "placeholder": "e.g. 2.40",
            "defaultRate": 0,
            "dbColumn": {
              "type": "NUMERIC(10,4)",
              "default": 0
            }
          }
        },
        {
          "type": "counter",
          "name": "autofuelfail",
          "subHeader": "Fuel Missed",
          "variant": "Fail",
          "dbColumn": {
            "type": "INTEGER",
            "default": 0
          }
        },
        {
          "type": "singleSelect",
          "name": "autoclimb",
          "label": "Auto Climb",
          "dbColumn": {
            "type": "INTEGER",
            "default": 0
          },
          "options": [
            {
              "value": 0,
              "label": "None",
              "default": true
            },
            {
              "value": 1,
              "label": "Level 1 (15 pts)"
            }
          ]
        }
      ]
    },
    {
      "id": "tele",
      "header": "Tele",
      "showWhen": {
        "field": "noshow",
        "equals": false
      },
      "fields": [
        {
          "type": "holdTimer",
          "name": "telefuelsuccess",
          "label": "Tele Fuel Time (s)",
          "buttonLabel": "Hold While Shooting Tele Fuel",
          "precision": 2,
          "dbColumn": {
            "type": "NUMERIC(10,3)",
            "default": 0
          },
          "scoutLeads": {
            "rateLabel": "Tele Balls / Second",
            "placeholder": "e.g. 2.70",
            "defaultRate": 0,
            "dbColumn": {
              "type": "NUMERIC(10,4)",
              "default": 0
            }
          }
        },
        {
          "type": "counter",
          "name": "telefuelfail",
          "subHeader": "Fuel Missed",
          "variant": "Fail",
          "dbColumn": {
            "type": "INTEGER",
            "default": 0
          }
        },
        {
          "type": "table",
          "id": "teleHPTable",
          "subHeader": "Human Player",
          "columns": [
            "",
            "Success",
            "Fail",
            ""
          ],
          "rows": [
            {
              "label": "",
              "fields": [
                {
                  "type": "counter",
                  "name": "hpsuccess",
                  "variant": "Success",
                  "dbColumn": {
                    "type": "INTEGER",
                    "default": 0
                  }
                },
                {
                  "type": "counter",
                  "name": "hpfail",
                  "variant": "Fail",
                  "dbColumn": {
                    "type": "INTEGER",
                    "default": 0
                  }
                }
              ]
            }
          ]
        },
        {
          "type": "comment",
          "name": "generalcomments",
          "label": "General Comments",
          "dbColumn": {
            "type": "TEXT",
            "default": null
          }
        },
        {
          "type": "collapsible",
          "id": "defenseSection",
          "trigger": {
            "type": "checkbox",
            "name": "defense",
            "label": "Playing Defense?",
            "dbColumn": {
              "type": "BOOLEAN",
              "default": false
            }
          },
          "content": [
            {
              "type": "comment",
              "name": "defensecomments",
              "label": "Defense Elaboration",
              "dbColumn": {
                "type": "TEXT",
                "default": null
              }
            },
            {
              "type": "starRating",
              "name": "defenseplayed",
              "label": "Defense Played",
              "description": "Ability to Play Defense",
              "max": 6,
              "minWhenVisible": 1,
              "dbColumn": {
                "type": "INTEGER",
                "default": null
              }
            }
          ]
        }
      ]
    },
    {
      "id": "endgame",
      "header": "Endgame",
      "showWhen": {
        "field": "noshow",
        "equals": false
      },
      "fields": [
        {
          "type": "singleSelect",
          "name": "endlocation",
          "label": "Tower Climb",
          "dbColumn": {
            "type": "INTEGER",
            "default": 0
          },
          "options": [
            {
              "value": 0,
              "label": "None",
              "default": true
            },
            {
              "value": 1,
              "label": "Level 1 (10 pts)"
            },
            {
              "value": 2,
              "label": "Level 2 (20 pts)"
            },
            {
              "value": 3,
              "label": "Level 3 (30 pts)"
            },
            {
              "value": 4,
              "label": "Failed Climb"
            }
          ]
        }
      ]
    },
    {
      "id": "postMatch",
      "header": "Post-Match",
      "showWhen": {
        "field": "noshow",
        "equals": false
      },
      "fields": [
        {
          "type": "multiSelect",
          "subHeader": "Intake",
          "name": "intakeOptions",
          "options": [
            {
              "name": "fuelgrndintake",
              "label": "Fuel Ground",
              "dbColumn": {
                "type": "BOOLEAN",
                "default": false
              }
            },
            {
              "name": "fueldepotintake",
              "label": "Fuel Depot",
              "dbColumn": {
                "type": "BOOLEAN",
                "default": false
              }
            },
            {
              "name": "fueloutpostintake",
              "label": "Fuel Outpost (HP)",
              "dbColumn": {
                "type": "BOOLEAN",
                "default": false
              }
            }
          ]
        },
        {
          "type": "multiSelect",
          "subHeader": "Field Traversal",
          "name": "traversalOptions",
          "options": [
            {
              "name": "usesbump",
              "label": "Uses Bump",
              "dbColumn": {
                "type": "BOOLEAN",
                "default": false
              }
            },
            {
              "name": "usestrench",
              "label": "Uses Trench",
              "dbColumn": {
                "type": "BOOLEAN",
                "default": false
              }
            }
          ]
        },
        {
          "type": "collapsible",
          "id": "breakdownSection",
          "trigger": {
            "type": "checkbox",
            "name": "breakdown",
            "label": "Broke down?",
            "dbColumn": {
              "type": "BOOLEAN",
              "default": false
            }
          },
          "content": [
            {
              "type": "comment",
              "name": "breakdowncomments",
              "label": "Breakdown Elaboration",
              "dbColumn": {
                "type": "TEXT",
                "default": null
              }
            }
          ]
        }
      ]
    },
    {
      "id": "qualitative",
      "header": "Qualitative Ratings",
      "showWhen": {
        "field": "noshow",
        "equals": false
      },
      "hidden": true,
      "description": "These fields are for internal tracking and not shown on the main form",
      "fields": [
        {
          "type": "starRating",
          "name": "shootingspeed",
          "label": "Shooting Speed",
          "max": 6,
          "dbColumn": {
            "type": "INTEGER",
            "default": null
          }
        },
        {
          "type": "starRating",
          "name": "shootingaccuracy",
          "label": "Shooting Accuracy",
          "max": 6,
          "dbColumn": {
            "type": "INTEGER",
            "default": null
          }
        },
        {
          "type": "starRating",
          "name": "intakespeed",
          "label": "Intake Speed",
          "max": 6,
          "dbColumn": {
            "type": "INTEGER",
            "default": null
          }
        },
        {
          "type": "starRating",
          "name": "climbspeed",
          "label": "Climb Speed",
          "max": 6,
          "dbColumn": {
            "type": "INTEGER",
            "default": null
          }
        },
        {
          "type": "starRating",
          "name": "maneuverability",
          "label": "Maneuverability",
          "max": 6,
          "dbColumn": {
            "type": "INTEGER",
            "default": null
          }
        },
        {
          "type": "starRating",
          "name": "defenseevasion",
          "label": "Defense Evasion",
          "max": 6,
          "dbColumn": {
            "type": "INTEGER",
            "default": null
          }
        },
        {
          "type": "starRating",
          "name": "aggression",
          "label": "Aggression",
          "max": 6,
          "inverted": true,
          "dbColumn": {
            "type": "INTEGER",
            "default": null
          }
        }
      ]
    }
  ],
  "calculations": {
    "auto": {
      "formula": "autofuelsuccess + (autoclimb==1?15:0)",
      "fields": [
        "autofuelsuccess",
        "autoclimb"
      ]
    },
    "tele": {
      "formula": "telefuelsuccess + hpsuccess",
      "fields": [
        "telefuelsuccess",
        "hpsuccess"
      ]
    },
    "end": {
      "type": "mapping",
      "field": "endlocation",
      "mapping": {
        "0": 0,
        "1": 10,
        "2": 20,
        "3": 30,
        "4": 0
      }
    }
  },
