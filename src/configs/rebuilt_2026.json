          "content": [
            {
              "type": "starRating",
              "name": "autoshootonthemoverating",
              "label": "Shooting While Moving (Auto)",
              "description": "How well did the robot maintain speed and accuracy while shooting on the move during auto?",
              "max": 4,
              "ratingLabels": [
                "Robot slows significantly AND most shots miss while moving",
                "Robot maintains speed OR accuracy, but not both",
                "Robot maintains moderate speed and lands most shots",
                "Robot maintains full speed with consistent shot accuracy"
              ],
              "minWhenVisible": 1,
              "dbColumn": {
                "type": "INTEGER",
                "default": null
              }
            }
          ]
        },
        {
          "type": "starRating",
          "name": "autoshootingrate",
          "label": "Shooting Rate (Auto)",
          "description": "Estimated average fuel pieces scored per second during autonomous period",
          "max": 5,
          "ratingLabels": [
            "Under 1 fuel/sec",
            "1-4 fuel/sec",
            "5-10 fuel/sec",
            "11-20 fuel/sec",
            "20+ fuel/sec"
